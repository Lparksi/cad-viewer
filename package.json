{
  "name": "mlightcad",
  "private": true,
  "version": "1.0.0",
  "license": "MIT",
  "author": "MLight Lee <mlight.lee@outlook.com>",
  "type": "module",
  "packageManager": "bun@1.3.10",
  "repository": {
    "type": "git",
    "url": "https://github.com/mlightcad/cad-viewer"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "analyze": "nx run-many -t analyze",
    "build": "nx run-many -t build",
    "clean": "nx run-many -t clean",
    "dev": "nx run @mlightcad/cad-viewer-example:dev",
    "dev:simple": "nx run @mlightcad/cad-simple-viewer-example:dev",
    "doc": "typedoc",
    "format": "prettier --config ./.prettierrc.js --write \"packages/**/*.{ts,js,vue,json}\"",
    "lint": "nx run-many -t lint",
    "lint:fix": "nx run-many -t lint:fix",
    "preview": "nx run @mlightcad/cad-viewer-example:preview",
    "preview:simple": "nx run @mlightcad/cad-simple-viewer-example:preview",
    "pre-serve": "nx run @mlightcad/cad-viewer-examples:pre-serve",
    "publish-viewer": "bun publish --cwd packages/cad-viewer && bun publish --cwd packages/cad-simple-viewer",
    "release": "node tools/release.mjs",
    "serve": "nx run @mlightcad/cad-viewer-examples:serve",
    "test": "jest"
  },
  "engines": {
    "bun": ">=1.3.8"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@intlify/eslint-plugin-vue-i18n": "^4.3.0",
    "@nx/js": "22.5.3",
    "@types/jest": "^30.0.0",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.3.3",
    "@types/rollup-plugin-peer-deps-external": "^2.2.6",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "jest": "^30.2.0",
    "lint-staged": "^16.3.2",
    "nx": "22.5.3",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-visualizer": "^7.0.1",
    "ts-jest": "^29.4.6",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vite-plugin-static-copy": "^3.2.0"
  },
  "lint-staged": {
    "*.{ts,js,vue}": [
      "prettier --config ./.prettierrc.js --write",
      "eslint --config ./.eslintrc.js --fix --quiet"
    ],
    "*.md": [
      "prettier --config ./.prettierrc.js --write"
    ]
  }
}
